          },
          {
            "icon": "HandCoins",
            "id": "card_record_repayment",
            "navigate_to": "SCR-record-repayment",
            "title": "Registrar pago de préstamo"
          },
          {
            "icon": "AlertCircle",
            "id": "card_view_arrears",
            "navigate_to": "SCR-ar-aging",
            "title": "Ver atrasos"
          },
          {
            "icon": "ScrollText",
            "id": "card_record_movement",
            "navigate_to": "SCR-record-movement",
            "title": "Registrar movimiento"
          }
