{
  "description": "Member list with filter + search per US-026/031.",
  "id": "SCR-members-list",
  "layout": {
    "kind": "listing",
    "sections": [
      {
        "fields": [
          {
            "id": "status",
            "label": "Estado",
            "options": [
              "activo",
              "en_pausa",
              "baja"
            ],
            "type": "select"
          }
        ],
        "id": "filter_bar",
        "type": "filters"
      },
      {
        "fields": [
          {
            "id": "q",
            "label": "Buscar socia",
            "type": "text"
          }
        ],
        "id": "search",
