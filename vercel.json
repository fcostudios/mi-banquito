{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build",
  "devCommand": "pnpm --filter mi-banquito-web dev",
  "outputDirectory": "apps/web/.next",
  "crons": [
    {
      "path": "/api/cron/accrue-interest",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/award-treasurer-compensation",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/drift-check",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/promise-reminders",
      "schedule": "35 5 * * *"
    }
  ]
}
