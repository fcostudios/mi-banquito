{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "APP_BASE_URL",
    "AUTH0_CLIENT_ID",
    "AUTH0_CLIENT_SECRET",
    "AUTH0_DOMAIN",
    "AUTH0_ORGANIZATION",
    "AUTH0_SECRET",
    "CRON_SECRET",
    "DATABASE_URL",
    "DB_DRIVER",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_SENTRY_DSN",
    "SENTRY_DSN",
    "VERCEL_BLOB_READ_WRITE_TOKEN"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "type-check": {
      "dependsOn": [
        "^build"
      ]
    },
    "lint": {},
    "test": {
      "dependsOn": [
        "^build"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
