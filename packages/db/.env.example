# packages/db — database env (drizzle-kit + verify-schema run here).
# IMP-259 driver auto-select: a standard Postgres URL → node-postgres
# (local dev/CI; `drizzle-kit push` applies locally); a *.neon.tech URL
# → neon-http (prod). Override with DB_DRIVER=pg|neon.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app
