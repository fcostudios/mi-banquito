{
  "consumer": {
    "name": "mi-banquito-web"
  },
  "interactions": [
    {
      "description": "a paginated candidate listing request",
      "providerStates": [
        {
          "name": "candidate objects exist after an interrupted expense write"
        }
      ],
      "request": {
        "headers": {
          "authorization": "Bearer vercel_blob_rw_contract_secret",
          "x-vercel-blob-store-id": "contract"
        },
        "method": "GET",
        "path": "/",
        "query": {
          "cursor": [
            "page-one"
          ],
          "limit": [
            "1000"
          ],
          "prefix": [
            "expense-slip-candidates/"
          ]
        }
      },
      "response": {
        "body": {
          "blobs": [
            {
              "downloadUrl": "https://contract.private.blob.vercel-storage.com/expense-slip-candidates/org/request/orphan.png?download=1",
              "etag": "list-etag",
              "pathname": "expense-slip-candidates/org/request/orphan.png",
              "size": 68,
              "uploadedAt": "2026-07-10T12:00:00.000Z",
              "url": "https://contract.private.blob.vercel-storage.com/expense-slip-candidates/org/request/orphan.png"
            }
          ],
          "cursor": "next-page",
          "hasMore": true
        },
        "headers": {
          "Content-Type": "application/json",
          "content-type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.blobs[0].downloadUrl": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.blobs[0].url": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a private non-overwriting receipt upload",
      "providerStates": [
        {
          "name": "the Blob store accepts private uploads"
        }
      ],
      "request": {
        "headers": {
          "authorization": "Bearer vercel_blob_rw_contract_secret",
          "x-add-random-suffix": "0",
          "x-allow-overwrite": "0",
          "x-content-type": "image/png",
          "x-vercel-blob-access": "private",
          "x-vercel-blob-store-id": "contract"
        },
        "method": "PUT",
        "path": "/",
        "query": {
          "pathname": [
            "expense-slip-candidates/pact-receipt.png"
          ]
        }
      },
      "response": {
        "body": {
          "contentDisposition": "inline",
          "contentType": "image/png",
          "downloadUrl": "https://contract.private.blob.vercel-storage.com/expense-slip-candidates/pact-receipt.png?download=1",
          "etag": "contract-etag",
          "pathname": "expense-slip-candidates/pact-receipt.png",
          "url": "https://contract.private.blob.vercel-storage.com/expense-slip-candidates/pact-receipt.png"
        },
        "headers": {
          "Content-Type": "application/json",
          "content-type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.downloadUrl": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.etag": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.url": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to delete one orphan",
      "providerStates": [
        {
          "name": "the orphan exists in the Blob store"
        }
      ],
      "request": {
        "body": {
          "urls": [
            "https://contract.private.blob.vercel-storage.com/expense-slip-candidates/org/request/orphan.png"
          ]
        },
        "headers": {
          "Content-Type": "application/json",
          "authorization": "Bearer vercel_blob_rw_contract_secret",
          "x-vercel-blob-store-id": "contract"
        },
        "method": "POST",
        "path": "/delete"
      },
      "response": {
        "body": {},
        "headers": {
          "Content-Type": "application/json",
          "content-type": "application/json"
        },
        "status": 200
      }
    },
    {
      "description": "an authenticated private tenant export download",
      "providerStates": [
        {
          "name": "the completed private tenant export exists"
        }
      ],
      "request": {
        "headers": {
          "authorization": "Bearer vercel_blob_rw_contract_secret"
        },
        "method": "GET",
        "path": "/tenant-exports/11111111-1111-4111-8111-111111111111/export.zip"
      },
      "response": {
        "body": "private-zip-stream",
        "headers": {
          "Content-Type": "application/zip",
          "content-length": "18",
          "content-type": "application/zip",
          "etag": "get-etag",
          "last-modified": "Sun, 12 Jul 2026 12:00:00 GMT"
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "17.0.1"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "vercel-blob-api"
  }
}