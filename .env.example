# Mi Banquito — Environment Variables (serverless / Next.js)
#
# The runtime env lives in apps/web/.env — copy apps/web/.env.example to
# apps/web/.env and fill it in. This root file is a pointer + the shared
# database contract.

# DATABASE_URL — the runtime db client uses node-postgres by default because
# app writes require transactions. Use DB_DRIVER=neon-http only for explicit
# read-only/tooling paths; legacy DB_DRIVER=neon is accepted but treated like pg.
#   Local dev (default):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app
#   Prod (Neon): DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require
DB_DRIVER=pg

APP_BASE_URL=http://localhost:3000
AUTH0_DOMAIN=dev-example.us.auth0.com
AUTH0_CLIENT_ID=replace-with-auth0-client-id
AUTH0_CLIENT_SECRET=replace-with-auth0-client-secret
AUTH0_SECRET=replace-with-32-byte-hex-secret
AUTH0_ORGANIZATION=org_replace_me
AUTH0_ORGANIZATION_DB_ORG_ID=11111111-1111-4111-8111-111111111111
CRON_SECRET=replace-with-cron-secret
NEXT_PUBLIC_API_URL=http://localhost:3000
SENTRY_DSN=https://public@example.ingest.sentry.io/1
NEXT_PUBLIC_SENTRY_DSN=https://public@example.ingest.sentry.io/1
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_replace_me
